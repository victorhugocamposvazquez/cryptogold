#!/bin/sh
# Bloquea push si origin tiene commits que no están en local.
# Evita el error "fetch first" al trabajar desde Cursor desktop + iOS.

remote="$1"

zero="0000000000000000000000000000000000000000"

git fetch "$remote" --quiet 2>/dev/null || true

while read local_ref local_oid remote_ref remote_oid; do
  if [ "$local_oid" = "$zero" ]; then
    continue
  fi
  if [ "$remote_oid" = "$zero" ]; then
    continue
  fi

  branch="${remote_ref#refs/heads/}"
  remote_head=$(git rev-parse "$remote/$branch" 2>/dev/null) || continue

  if git merge-base --is-ancestor "$remote_head" "$local_oid" 2>/dev/null; then
    continue
  fi

  echo ""
  echo "Push bloqueado: origin/$branch tiene commits que no tienes aquí."
  echo "(Suele pasar al alternar Cursor desktop y Cursor iOS en el mismo repo.)"
  echo ""
  echo "  git pull --rebase origin $branch"
  echo "  git push origin $branch"
  echo ""
  exit 1
done

exit 0
