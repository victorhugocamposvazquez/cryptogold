# ── BNB Smart Chain Testnet (chainId 97) ──
# Faucet: https://www.bnbchain.org/en/testnet-faucet
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Clave privada del deployer (sin 0x). NUNCA commitear.
DEPLOYER_PRIVATE_KEY=

# Wallet que recibe los 12.000M CGOLD (vacío = misma que deployer)
TREASURY_ADDRESS=

# Tokens enteros minteados al treasury en el deploy (0 = todo minteable desde backoffice)
INITIAL_TREASURY_MINT_TOKENS=0

# Para verificar en BscScan tras el deploy
BSCSCAN_API_KEY=

# ── Mainnet (chainId 56) — solo cuando pases a producción ──
# BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org
