# ── Supabase (https://supabase.com/dashboard) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Solo servidor — webhooks y cron. NUNCA expongas en el cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── CRYPTOHOST backoffice (/admin) ──
CRYPTOHOST_ADMIN_PASSWORD=cryptohost-dev

# ── Pagos fiat (Transak / MoonPay) ──
PAYMENT_WEBHOOK_SECRET=whsec_...

# ══════════════════════════════════════════════════════════════
# RED ACTIVA — una sola variable cambia test ↔ main
# ══════════════════════════════════════════════════════════════
NEXT_PUBLIC_BNB_NETWORK=testnet
# Valores: testnet | mainnet

# ── PERFIL TESTNET (chainId 97) ───────────────────────────────
NEXT_PUBLIC_CGOLD_BNB_TESTNET=0x...
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
CGOLD_TREASURY_ADDRESS_TESTNET=0x...
TOKEN_OWNER_PRIVATE_KEY_TESTNET=
TOKEN_DEPLOYER_PRIVATE_KEY_TESTNET=

# ── PERFIL MAINNET (chainId 56) ───────────────────────────────
NEXT_PUBLIC_CGOLD_BNB=0x...
BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org
CGOLD_TREASURY_ADDRESS_MAINNET=0x...
TOKEN_OWNER_PRIVATE_KEY_MAINNET=
TOKEN_DEPLOYER_PRIVATE_KEY_MAINNET=

# ── Fallbacks globales (opcional — si no hay *_TESTNET / *_MAINNET) ──
# CGOLD_TREASURY_ADDRESS=0x...
# TOKEN_OWNER_PRIVATE_KEY=
# TOKEN_DEPLOYER_PRIVATE_KEY=

# ── Otras cadenas (fase posterior) ──
# NEXT_PUBLIC_CGOLD_ETH=0x...
# NEXT_PUBLIC_CGOLD_POLYGON=0x...

# ── Wallet (opcional — Fase 3+) ──
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Ver plantilla completa y estado en /admin/red
