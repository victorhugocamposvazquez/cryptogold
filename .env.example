# ── Supabase (https://supabase.com/dashboard) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Solo servidor — webhooks y cron. NUNCA expongas en el cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── CRYPTOHOST backoffice (/admin) ──
CRYPTOHOST_ADMIN_PASSWORD=cryptohost-dev

# ── Pagos fiat (Transak / MoonPay) ──
# Secreto para validar webhooks entrantes en /api/webhooks/payment
PAYMENT_WEBHOOK_SECRET=whsec_...

# ── Wallet (opcional — Fase 3+) ──
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Contratos on-chain ──
# Red activa: testnet (BNB Smart Chain Testnet, chainId 97) | mainnet
NEXT_PUBLIC_BNB_NETWORK=testnet
# Tras deploy en testnet (ver contracts/README.md):
# NEXT_PUBLIC_CGOLD_BNB_TESTNET=0x...
# Clave del owner del contrato (solo servidor — habilita mint en /admin/token)
# TOKEN_OWNER_PRIVATE_KEY=
# Wallet tesorería para mostrar balance en backoffice (opcional)
# CGOLD_TREASURY_ADDRESS=0x...
# Mainnet (fase posterior):
# NEXT_PUBLIC_CGOLD_BNB=0x...
# NEXT_PUBLIC_CGOLD_ETH=0x...
