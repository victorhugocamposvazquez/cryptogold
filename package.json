    "react-dom": "18.3.1",
    "viem": "^2.31.0"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "typescript": "5.5.3"
  },
  "comments": {
    "supabase": "Para conectar Supabase: npm i @supabase/supabase-js @supabase/ssr",
    "wallet": "Para wallet real: npm i wagmi viem @rainbow-me/rainbowkit",
    "onramp": "Para pago con tarjeta real: npm i @transak/transak-sdk  (o @moonpay/moonpay-react)"
  }
