    "contracts:deploy:testnet": "cd contracts && ./deploy-testnet.sh"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "next": "14.2.5",
