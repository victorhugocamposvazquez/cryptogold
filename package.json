{
  "name": "cryptogold",
  "version": "1.0.0",
  "private": true,
  "description": "CryptoGold — plataforma del token CGOLD respaldado en oro. Next.js + Supabase + Vercel.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
